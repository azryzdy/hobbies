        <mxCell id="CB5kWWDTfhdYCPDuGdY6-44" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Governor/Amir" vertex="1">
          <mxGeometry height="60" width="120" x="300" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="CB5kWWDTfhdYCPDuGdY6-46" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Tribal leaders/ashraf provided the link between the&amp;nbsp;governor and the tribesmen. This meant that they had to be&amp;nbsp;acceptable to both parties, to the government and to the tribesmen." vertex="1">
          <mxGeometry height="90" width="260" x="60" y="1605" as="geometry" />
        </mxCell>
        <mxCell id="CB5kWWDTfhdYCPDuGdY6-47" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="They owed their position among the tribesmen usually to their descent from an hereditary leading family, but as agents of the&lt;br&gt;government they were appointed from above rather than below, by the governor or even the caliph, not by the tribesmen." vertex="1">
          <mxGeometry height="90" width="260" x="365" y="1605" as="geometry" />
        </mxCell>
        <mxCell id="CB5kWWDTfhdYCPDuGdY6-50" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Their position was not always a comfortable one and from time to time the ashraf had to come down off the fence and side either with the government&amp;nbsp;or with the tribesmen." vertex="1">
          <mxGeometry height="90" width="260" x="670" y="1605" as="geometry" />
        </mxCell>
